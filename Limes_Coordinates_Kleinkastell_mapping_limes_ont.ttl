@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://purl.org/suni/limestown> a owl:ObjectProperty ;
    rdfs:label "limestown"@en .

<http://purl.org/suni/limestownpart> a owl:DatatypeProperty ;
    rdfs:label "limestownpart"@en .

rdfs:comment a owl:AnnotationProperty ;
    rdfs:label "limesobject"@en .

rdfs:label a owl:AnnotationProperty ;
    rdfs:label "label"@en .

